{
  "permissions": {
    "allow": [
      "Bash",
      "mcp__playwright",
      "mcp__deepwiki",
      "WebFetch",
      "TodoWrite"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      ".data",
      ".vscode",
      ".claude",
      ".ai",
      "~/amplifier"
    ]
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": ["playwright", "context7", "deepwiki", "repomix", "gitea"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/hook_session_start.py",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/hook_memory_sync.py",
            "timeout": 20000
          },
          {
            "type": "command",
            "command": "bash /opt/amplifier/scripts/observers/drift-detector.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/hook_stop.py"
          },
          {
            "type": "command",
            "command": "bash /opt/amplifier/.claude/hooks/session-end-index.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/hook_stop.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/subagent-validator.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/subagent-logger.py"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/amplifier/.claude/tools/enforce-brainstorm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/amplifier/.claude/tools/on_code_change_hook.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/amplifier/scripts/observers/build-watcher.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ \"${MEMORY_SYSTEM_ENABLED:-false}\" = \"true\" ]; then cd /opt/amplifier && uv run .claude/tools/hook_post_tool_use.py; fi'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/on_notification_hook.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd /opt/amplifier && uv run .claude/tools/hook_precompact.py",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
