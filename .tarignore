# Files and directories to exclude from the installer archive
# Version control
.git/
.gitignore
.github/

# Python artifacts
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# Claude logs and cache
.claude/

# Temporary and log files
*.log
*.tmp
*.temp
*.cache
.ruff_cache/

# Data directories
.data/
ai_working/

# Test coverage
.coverage
htmlcov/
*.cover
.hypothesis/

# Installer-specific excludes
install_amplifier.sh
tools/build_installer.sh
.tarignore
.install_state

# Local configuration
.env.local
.env.development
.env.production